{
  "$schema": "https://schemas.wp.org/trunk/wp-env.json",
  "core": "https://downloads.wordpress.org/release/wordpress-7.0.2.zip",
  "phpVersion": "8.3",
  "port": 8888,
  "testsPort": 8889,
  "themes": [
    "./wordpress/wp-content/themes/cywater"
  ],
  "plugins": [
    "./wordpress/wp-content/plugins/cywater-core",
    "./wordpress/wp-content/plugins/cywater-membership",
    "./wordpress/wp-content/plugins/cywater-environment",
    "./wordpress/runtime/vendor/paid-memberships-pro"
  ],
  "config": {
    "WP_DEBUG": true,
    "WP_DEBUG_LOG": true,
    "WP_DEBUG_DISPLAY": false,
    "WP_ENVIRONMENT_TYPE": "local",
    "DISALLOW_FILE_EDIT": true,
    "CYWATER_PAYMENT_MODE": "test",
    "CYWATER_ALLOW_LIVE_PAYMENTS": false,
    "CYWATER_MAIL_TRANSPORT": "mailpit",
    "CYWATER_ENABLE_CALENDAR_YEAR_END": true
  }
}
