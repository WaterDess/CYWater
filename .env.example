# Copy to .env only when a local tool explicitly requires it.
# Never commit .env or real credentials.
CYWATER_ENVIRONMENT=local
CYWATER_PAYMENT_MODE=test
CYWATER_ALLOW_LIVE_PAYMENTS=false
CYWATER_MAIL_TRANSPORT=mailpit
CYWATER_ENABLE_CALENDAR_YEAR_END=true
MAILPIT_HOST=host.docker.internal
MAILPIT_PORT=1025

# Stripe test values only. Leave blank until an organization-owned sandbox exists.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Production SMTP is deliberately unset during local development.
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
